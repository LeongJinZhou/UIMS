# ============================================
# UIMS Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- Database (PostgreSQL 16) ---
DATABASE_URL="postgresql://university_admin:changeme@localhost:5432/uims?schema=public"
POSTGRES_USER=university_admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=uims

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=university_minio
MINIO_ROOT_PASSWORD=changeme_minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=university-documents

# --- JWT Authentication ---
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=7d

# --- AI / LLM ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# --- OR-Tools Solver Service ---
SOLVER_SERVICE_URL=http://localhost:8000

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@university.edu.my

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1234567890

# --- Application ---
NODE_ENV=development
PORT=3000
WEB_URL=http://localhost:5173
API_URL=http://localhost:3000

# --- Meilisearch (optional) ---
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=changeme_meili
